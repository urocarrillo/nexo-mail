# Brevo API Key - Get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxx

# API Secret for webhook authentication - Generate with: openssl rand -base64 32
API_SECRET_KEY=your-secret-key-here

# WooCommerce Webhook Secret - Generate with: openssl rand -base64 32
WOOCOMMERCE_WEBHOOK_SECRET=your-woocommerce-secret-here

# WordPress App Password for WooCommerce REST API (coupon creation)
WP_APP_PASSWORD=your-wp-app-password

# Calendly post-consultation email
CALENDLY_EMAIL_TEMPLATE_ID=158
CALENDLY_WEBHOOK_SECRET=your-calendly-signing-key

# Zernio API Key for LinkedIn posting - Get from https://zernio.com
ZERNIO_API_KEY=sk_xxx

# Vercel KV (automatically added when you create a KV store in Vercel)
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
