{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 10
    },
    "src/app/api/cron/send-emails/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/weekly-newsletter/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/weekly-blog/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/verify-blog/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/process-calendly/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/cleanup-coupons/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/send-emails",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/weekly-blog",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/verify-blog",
      "schedule": "30 13 * * 1"
    },
    {
      "path": "/api/cron/weekly-blog",
      "schedule": "0 11 * * 2"
    },
    {
      "path": "/api/cron/verify-blog",
      "schedule": "0 12 * * 2"
    },
    {
      "path": "/api/cron/weekly-newsletter",
      "schedule": "0 13 * * 2"
    },
    {
      "path": "/api/cron/process-calendly",
      "schedule": "30 */2 * * *"
    },
    {
      "path": "/api/cron/cleanup-coupons",
      "schedule": "0 6 * * *"
    }
  ]
}
